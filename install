(set install_path (get (argv) 0))
(print ".... installing application in ${install_path}")
(exec "make clean && make")
(exec "cp notepad ${install_path}/notepad")
(exec "cp -r ./themes ${install_path}/themes")
(exec "cp -r ./syntax ${install_path}/syntax")
(set config (read "notepad.config.json"))
(write "${install_path}/notepad.config.json" (replace config "./" "${install_path}/"))
(print (exec "ls -ltr ${install_path}") "!!!Installed Notepad")


{
  "theme":       "darks",
  "grammar":     "./syntax/c.tmLanguage.json",
  "font_size":   18,
  "line_height": 22,
  "tab_width":   4,
  "window_w":    1100,
  "window_h":    720,
  "gutter_w":    60,

  "themes": {
    "darks":          "./themes/dark.json",
    "light":          "./themes/light.json",
    "solarized-dark": "./themes/solarized-dark.json",
    "basic":          "./themes/basic.json",
    "clear-dark":     "./themes/clear-dark.json",
    "clear-light":    "./themes/clear-light.json",
    "grass":          "./themes/grass.json"
  },

  "$schema": {
    "**.c": {
      "file_extensions": [".c", ".h"],
      "name":            "C",
      "grammar":         "./syntax/c.tmLanguage.json",
      "line_comment":    "// "
    },
    "**.js": {
      "file_extensions": [".js", ".mjs", ".cjs", ".jsx", ".ts", ".tsx"],
      "name":            "JavaScript",
      "grammar":         "./syntax/js.tmLanguage.json",
      "line_comment":    "// "
    },
    "**.py": {
      "file_extensions": [".py", ".pyw", ".pyi"],
      "name":            "Python",
      "grammar":         "./syntax/python.tmLanguage.json",
      "line_comment":    "# "
    },
    "**.z": {
      "file_extensions": [".z"],
      "name":            "Z",
      "grammar":         "./syntax/z.tmLanguage.json",
      "line_comment":    "; "
    }
  },

  "snippets": {
    "C": {
      "for":  "for (int i = 0; i < N; i++) {\n    \n}",
      "if":   "if () {\n    \n}",
      "main": "int main(int argc, char **argv) {\n    return 0;\n}"
    },
    "JavaScript": {
      "for":  "for (let i = 0; i < n; i++) {\n    \n}",
      "fn":   "function name() {\n    \n}",
      "log":  "console.log();"
    },
    "Python": {
      "for":  "for i in range(n):\n    pass",
      "def":  "def name():\n    pass",
      "if":   "if :\n    pass"
    },
    "Z": {
      "fn":   "(fn name (args) )",
      "let":  "(let ((x 0)) )",
      "if":   "(if  )",
      "print" :"(print \"str\")"
    }
  }
}

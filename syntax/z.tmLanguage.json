{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Z",
  "scopeName": "source.z",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#fn-definition" },
    { "include": "#lambda-definition" },
    { "include": "#special-forms" },
    { "include": "#builtins-system" },
    { "include": "#builtins-collection" },
    { "include": "#builtins-string" },
    { "include": "#builtins-math" },
    { "include": "#builtins-io" },
    { "include": "#builtins-namespaced" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#number" },
    { "include": "#symbol" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.semicolon.z",
      "match": ";.*$"
    },
    "string": {
      "name": "string.quoted.double.z",
      "match": "\"([^\"\\\\]|\\\\.)*\""
    },
    "number": {
      "name": "constant.numeric.z",
      "match": "-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?"
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.z", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.null.z",    "match": "\\bnull\\b" }
      ]
    },
    "special-forms": {
      "name":  "keyword.control.z",
      "match": "(?<=\\()\\s*(do|if|while|for|fn|lambda|set|try|catch|quote|and|or|import|return|break|continue|match)\\b"
    },
    "fn-definition": {
      "match": "(\\()\\s*(fn)\\s+([A-Za-z_][A-Za-z0-9_!?:.-]*)",
      "captures": {
        "1": { "name": "punctuation.section.parens.begin.z" },
        "2": { "name": "keyword.control.z" },
        "3": { "name": "entity.name.function.z" }
      }
    },
    "lambda-definition": {
      "match": "(\\()\\s*(lambda)\\b",
      "captures": {
        "1": { "name": "punctuation.section.parens.begin.z" },
        "2": { "name": "keyword.control.z" }
      }
    },
    "builtins-system": {
      "name":  "support.function.system.z",
      "match": "(?<=\\(|\\s)(print|type|assert|sleep|now|timestamp|format-date|env|exec|run|argv|exit|import)\\b"
    },
    "builtins-collection": {
      "name":  "support.function.collection.z",
      "match": "(?<=\\(|\\s)(array|object|get|put|push|pop|length|keys|values|entries|map|filter|reduce)\\b"
    },
    "builtins-string": {
      "name":  "support.function.string.z",
      "match": "(?<=\\(|\\s)(concat|split|trim|lower|upper|replace|substring)\\b"
    },
    "builtins-math": {
      "name":  "support.function.math.z",
      "match": "(?<=\\(|\\s)(min|max|floor|ceil|abs|random)\\b"
    },
    "builtins-io": {
      "name":  "support.function.io.z",
      "match": "(?<=\\(|\\s)(read|write|append|delete)\\b"
    },
    "builtins-namespaced": {
      "name":  "support.function.namespaced.z",
      "match": "(?<=\\(|\\s)(json:parse|json:stringify|http:get|http:post)\\b"
    },
    "operators": {
      "name":  "keyword.operator.z",
      "match": "(?<=\\(|\\s)(\\+|\\-|\\*|/|%|<=|>=|==|!=|<|>|&&|\\|\\||!)(?=\\s|\\))"
    },
    "symbol": {
      "name":  "variable.other.z",
      "match": "[A-Za-z_][A-Za-z0-9_!?:.-]*"
    }
  }
}
